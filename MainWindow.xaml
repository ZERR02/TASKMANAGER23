<Window x:Class="TASKMANAGER23.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Manager" Height="450" Width="400">

    <StackPanel Margin="10">

        <TextBlock Margin="5" Text="{Binding AllTasks.Count, StringFormat=Всего задач: {0}}"/>


        <Border Background="#F0F0F0" Padding="5" Margin="0,0,0,10" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Поиск задач" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="SearchTextBox" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8"
                         FontSize="12"/>
            </StackPanel>
        </Border>


        <Button Content="Очистить поиск" 
                Click="ClearSearch_Click" 
                Margin="5,0,0,10"
                HorizontalAlignment="Left"
                Width="120">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasSearchText}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <StackPanel Orientation="Horizontal" Margin="0,10">
            <TextBox Width="250" 
                     Text="{Binding NewTaskText, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Добавить" Click="AddTask_Click" Margin="5,0"/>
        </StackPanel>

        <TextBlock Margin="5" 
                   Text="{Binding SearchStatus}" 
                   Foreground="Gray" 
                   FontSize="11">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasSearchText}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <ListBox ItemsSource="{Binding FilteredTasks}" Height="300">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <CheckBox IsChecked="{Binding IsCompleted}" Margin="5"/>
                        <TextBlock Text="{Binding Description}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>


        <Button Content="Показать все задачи" 
                Click="ShowAllTasks_Click" 
                Margin="0,10,0,0">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasSearchText}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </StackPanel>
</Window>